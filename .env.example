# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
NEXT_PUBLIC_NEGOCIOS_URL=your-negocios-public-url
NEXT_PUBLIC_CAPACITACION_URL=your-capacitacion-public-url

# Internal Docker network URLs (Coolify) — used server-side only for proxying (faster, no TLS/DNS overhead)
NEGOCIOS_INTERNAL_URL=http://sha-gestion-app
CAPACITACION_INTERNAL_URL=http://sha-capacitacion-app